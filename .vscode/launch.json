{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "name": "Watch",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "type": "node-terminal",
      "name": "Example: Angular",
      "request": "launch",
      "command": "npm start",
      "cwd": "${workspaceFolder}/examples/angular"
    },
    {
      "type": "node-terminal",
      "name": "Example: Python",
      "request": "launch",
      "command": "python manage.py runserver 0.0.0.0:8001",
      "cwd": "${workspaceFolder}/examples/django"
    }
  ]
}
